{
  "name": "@vanya2h/prettier-config",
  "version": "0.5.0-rc.0",
  "description": "A standard prettier config",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "clean": "rimraf ./dist",
    "dev": "tsc -w",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@vanya2h/typescript-config": "workspace:*",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
